# Your public domain (no scheme or trailing slash)
DOMAIN=your-domain.com

# Email used for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# PostgreSQL password (used internally; not exposed outside Docker network)
POSTGRES_PASSWORD=change_me

# Secrets — generate with: openssl rand -hex 32
JWT_SECRET=
SESSION_SECRET=

# GitHub OAuth app credentials
# Set the callback URL in your GitHub OAuth app to: https://DOMAIN/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
