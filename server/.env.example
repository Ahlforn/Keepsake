DATABASE_URL="postgresql://postgres:postgres@localhost:5432/keepsake?schema=public"
PORT=4000
CLIENT_URL="http://localhost:5173"  # set to https://yourdomain.com in production

# Generate a strong random secret for production
JWT_SECRET="change-me-to-a-long-random-string"
SESSION_SECRET="change-me-to-another-long-random-string"

# GitHub OAuth — create an app at https://github.com/settings/developers
